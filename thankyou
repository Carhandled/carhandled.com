  <style>
    /* ── Variables ─────────────────────────────────────── */
    :root {
      --gold:      #C6A972;
      --gold-dim:  #8A7248;
      --gold-lite: #E8C97A;
      --black:     #080808;
      --dark:      #0D0D0D;
      --panel:     #111111;
      --card:      #161616;
      --border:    #1E1E1E;
      --border2:   #2A2A2A;
      --ink:       #F0EEE9;
      --ink-dim:   #C0BDB7;
      --ink-mute:  #7A7875;
      --white:     #FFFFFF;
      --green:     #1A7A40;
      --green-dim: #0D3D20;
    }

    /* ── Reset ──────────────────────────────────────────── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html { font-size: 17px; scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', -apple-system, sans-serif;
      background: var(--dark);
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Grain */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: 0.025;
      pointer-events: none;
      z-index: 9999;
    }

    /* ── Diagonal stripes bg ────────────────────────────── */
    .page-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      background: var(--dark);
      overflow: hidden;
    }
    .page-bg::before {
      content: '';
      position: absolute;
      inset: -100px;
      background: repeating-linear-gradient(
        -52deg,
        transparent,
        transparent 68px,
        rgba(255,255,255,0.018) 68px,
        rgba(255,255,255,0.018) 69px
      );
    }
    /* Radial gold glow — bottom left, subtle */
    .page-bg::after {
      content: '';
      position: absolute;
      bottom: -200px;
      left: -100px;
      width: 700px;
      height: 700px;
      background: radial-gradient(ellipse, rgba(198,169,114,0.07) 0%, transparent 65%);
      pointer-events: none;
    }

    /* ── Layout ─────────────────────────────────────────── */
    .page-wrap {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 3rem 1.5rem 4rem;
    }

    /* ── Top bar ────────────────────────────────────────── */
    .topbar {
      background: rgba(8,8,8,0.9);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .topbar img { height: 36px; }

    /* ── Confirmation card ──────────────────────────────── */
    .confirm-card {
      width: 100%;
      max-width: 560px;
      background: var(--panel);
      border: 1px solid var(--border2);
      border-radius: 20px;
      overflow: hidden;
      box-shadow:
        0 0 0 1px rgba(198,169,114,0.06),
        0 32px 80px rgba(0,0,0,0.5);

      /* Entry animation */
      animation: card-enter 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @keyframes card-enter {
      from { opacity: 0; transform: translateY(28px) scale(0.97); }
      to   { opacity: 1; transform: none; }
    }

    /* ── Card header — dark with stripes ────────────────── */
    .card-header {
      background: linear-gradient(145deg, #111 0%, #0A0A0A 100%);
      border-bottom: 1px solid var(--border2);
      padding: 2.5rem 2rem 2rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .card-header::before {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 22px,
        rgba(255,255,255,0.015) 22px,
        rgba(255,255,255,0.015) 23px
      );
    }

    /* Shield icon with checkmark — animated */
    .shield-wrap {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.4rem;
      animation: shield-pop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
    }
    @keyframes shield-pop {
      from { opacity: 0; transform: scale(0.5) rotate(-8deg); }
      to   { opacity: 1; transform: scale(1) rotate(0deg); }
    }

    .shield-ring {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: rgba(198,169,114,0.08);
      border: 1px solid rgba(198,169,114,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    /* Pulse ring */
    .shield-ring::after {
      content: '';
      position: absolute;
      inset: -8px;
      border-radius: 50%;
      border: 1px solid rgba(198,169,114,0.15);
      animation: ring-pulse 2.5s ease-out 0.8s infinite;
    }
    @keyframes ring-pulse {
      0%   { transform: scale(1); opacity: 1; }
      100% { transform: scale(1.4); opacity: 0; }
    }

    .shield-icon { position: relative; z-index: 1; }

    .card-header h1 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 2.1rem;
      color: var(--white);
      line-height: 1.15;
      margin-bottom: 0.65rem;
      position: relative;
      z-index: 1;
    }
    .card-header h1 span { color: var(--gold); }

    .card-header p {
      color: var(--ink-dim);
      font-size: 0.95rem;
      line-height: 1.6;
      max-width: 380px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    /* ── Email notice ───────────────────────────────────── */
    .email-notice {
      margin: 1.5rem 2rem 0;
      background: rgba(26,122,64,0.1);
      border: 1px solid rgba(26,122,64,0.3);
      border-radius: 10px;
      padding: 0.9rem 1.1rem;
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      position: relative;
      z-index: 1;

      animation: fade-up 0.5s ease 0.5s both;
    }
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: none; }
    }

    .email-notice-icon {
      flex-shrink: 0;
      margin-top: 1px;
      color: #4CAF70;
    }

    .email-notice p {
      font-size: 0.88rem;
      color: var(--ink-dim);
      line-height: 1.55;
      text-align: left;
    }
    .email-notice p strong { color: #4CAF70; font-weight: 500; }

    /* ── Card body ──────────────────────────────────────── */
    .card-body {
      padding: 1.75rem 2rem 2rem;
    }

    /* ── Files included ─────────────────────────────────── */
    .files-label {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.85rem;
    }

    .files-list {
      background: var(--card);
      border: 1px solid var(--border2);
      border-radius: 10px;
      overflow: hidden;
      margin-bottom: 1.75rem;
    }

    .file-row {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--border);
      animation: fade-up 0.4s ease both;
    }
    .file-row:last-child { border-bottom: none; }
    .file-row:nth-child(1) { animation-delay: 0.6s; }
    .file-row:nth-child(2) { animation-delay: 0.68s; }
    .file-row:nth-child(3) { animation-delay: 0.76s; }
    .file-row:nth-child(4) { animation-delay: 0.84s; }
    .file-row:nth-child(5) { animation-delay: 0.92s; }
    .file-row:nth-child(6) { animation-delay: 1.0s; }
    .file-row:nth-child(7) { animation-delay: 1.08s; }
    .file-row:nth-child(8) { animation-delay: 1.16s; }
    .file-row:nth-child(9) { animation-delay: 1.24s; }

    .file-badge {
      width: 30px;
      height: 30px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      flex-shrink: 0;
    }
    .file-badge.pdf {
      background: rgba(160,42,30,0.15);
      color: #E07060;
      border: 1px solid rgba(160,42,30,0.2);
    }
    .file-badge.xls {
      background: rgba(26,122,64,0.15);
      color: #4CAF70;
      border: 1px solid rgba(26,122,64,0.2);
    }

    .file-name {
      font-size: 0.88rem;
      color: var(--ink-dim);
      flex: 1;
    }

    .file-type {
      font-size: 0.72rem;
      color: var(--ink-mute);
      flex-shrink: 0;
    }

    /* ── How to start ───────────────────────────────────── */
    .howto-label {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.85rem;
    }

    .steps-list {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      margin-bottom: 1.75rem;
    }

    .step-row {
      display: flex;
      align-items: flex-start;
      gap: 0.9rem;
      background: var(--card);
      border: 1px solid var(--border2);
      border-radius: 10px;
      padding: 0.85rem 1rem;
      animation: fade-up 0.4s ease both;
    }
    .step-row:nth-child(1) { animation-delay: 1.3s; }
    .step-row:nth-child(2) { animation-delay: 1.38s; }
    .step-row:nth-child(3) { animation-delay: 1.46s; }
    .step-row:nth-child(4) { animation-delay: 1.54s; }

    .step-num {
      width: 24px;
      height: 24px;
      background: var(--gold);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--black);
      flex-shrink: 0;
      margin-top: 1px;
    }

    .step-text {
      font-size: 0.9rem;
      color: var(--ink-dim);
      line-height: 1.5;
    }
    .step-text strong {
      color: var(--ink);
      font-weight: 500;
      display: block;
      margin-bottom: 0.15rem;
    }

    /* ── Share / next actions ───────────────────────────── */
    .actions-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.45rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      padding: 0.7rem 1.2rem;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.2s ease;
      text-decoration: none;
      border: none;
      flex: 1;
      min-width: 140px;
      text-align: center;
      -webkit-tap-highlight-color: transparent;
    }

    .btn--gold {
      background: var(--gold);
      color: var(--black);
    }
    .btn--gold:hover {
      background: var(--gold-lite);
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(198,169,114,0.22);
    }

    .btn--outline {
      background: transparent;
      color: var(--ink-dim);
      border: 1px solid var(--border2);
    }
    .btn--outline:hover {
      border-color: var(--gold-dim);
      color: var(--gold);
      background: rgba(198,169,114,0.05);
    }

    /* ── Guarantee strip ────────────────────────────────── */
    .guarantee {
      margin-top: 1.25rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      font-size: 0.78rem;
      color: var(--ink-mute);
    }

    /* ── Concierge upsell ───────────────────────────────── */
    .upsell {
      width: 100%;
      max-width: 560px;
      margin-top: 1.25rem;
      background: var(--panel);
      border: 1px solid var(--border2);
      border-left: 3px solid var(--gold-dim);
      border-radius: 14px;
      padding: 1.4rem 1.6rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
      flex-wrap: wrap;

      animation: fade-up 0.5s ease 1.7s both;
    }

    .upsell-text { flex: 1 1 220px; }
    .upsell-text p {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.35rem;
    }
    .upsell-text h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      color: var(--white);
      font-weight: 700;
      margin-bottom: 0.3rem;
    }
    .upsell-text span {
      font-size: 0.83rem;
      color: var(--ink-mute);
      line-height: 1.5;
    }

    .upsell-action { flex-shrink: 0; }
    .upsell-action a {
      display: inline-block;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--gold);
      border: 1px solid var(--gold-dim);
      border-radius: 8px;
      padding: 0.55rem 1rem;
      transition: all 0.2s ease;
      white-space: nowrap;
      -webkit-tap-highlight-color: transparent;
    }
    .upsell-action a:hover {
      background: rgba(198,169,114,0.08);
      border-color: var(--gold);
    }

    /* ── Footer ─────────────────────────────────────────── */
    .page-footer {
      text-align: center;
      padding: 1.5rem 1.5rem 2rem;
      font-size: 0.78rem;
      color: var(--ink-mute);
      position: relative;
      z-index: 1;
    }
    .page-footer a { color: var(--ink-mute); transition: color 0.15s; }
    .page-footer a:hover { color: var(--gold); }
    .page-footer .sep { margin: 0 0.6rem; opacity: 0.4; }

    /* ── Responsive ─────────────────────────────────────── */
    @media (max-width: 600px) {
      .main { padding: 2rem 1rem 3rem; }
      .card-header { padding: 2rem 1.25rem 1.5rem; }
      .card-header h1 { font-size: 1.7rem; }
      .email-notice { margin: 1.25rem 1.25rem 0; }
      .card-body { padding: 1.4rem 1.25rem 1.5rem; }
      .actions-row { flex-direction: column; }
      .btn { min-width: unset; width: 100%; }
      .upsell { padding: 1.2rem; gap: 1rem; }
      .upsell-action { width: 100%; }
      .upsell-action a { width: 100%; display: block; text-align: center; }
    }
  </style>
</head>

<body>
  <div class="page-bg" aria-hidden="true"></div>

  <div class="page-wrap">

    <!-- Top bar -->
    <div class="topbar">
      <a href="/" aria-label="CarHandled home">
        <img src="assets/img/logo.png" alt="CarHandled">
      </a>
    </div>

    <main class="main">

      <!-- Confirmation card -->
      <div class="confirm-card">

        <!-- Header -->
        <div class="card-header">

          <!-- Animated shield -->
          <div class="shield-wrap">
            <div class="shield-ring">
              <svg class="shield-icon" width="38" height="46" viewBox="0 0 38 46" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M19 1L2 8V20C2 31.5 9.5 41.5 19 45C28.5 41.5 36 31.5 36 20V8L19 1Z"
                  stroke="#C6A972" stroke-width="1.8" fill="rgba(198,169,114,0.08)"/>
                <path d="M12 23L16.5 27.5L26 18"
                  stroke="#C6A972" stroke-width="2.2"
                  stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>

          <h1>You're in.<br><span>The toolkit is yours.</span></h1>
          <p>
            Check your email — all 9 files are on their way to your inbox right now.
          </p>

          <!-- Email confirmed notice -->
          <div class="email-notice">
            <svg class="email-notice-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            <p>
              <strong>Check your inbox</strong> — the email with all attachments usually arrives within 60 seconds.
              If you don't see it, check your spam folder or reply to the confirmation email.
            </p>
          </div>

        </div>

        <!-- Body -->
        <div class="card-body">

          <!-- What's included -->
          <div class="files-label">What's attached to your email</div>

          <div class="files-list">
            <div class="file-row">
              <div class="file-badge pdf">PDF</div>
              <span class="file-name">CarHandled™ Toolkit — Main Guide</span>
              <span class="file-type">PDF</span>
            </div>
            <div class="file-row">
              <div class="file-badge pdf">PDF</div>
              <span class="file-name">CarHandled E-Book</span>
              <span class="file-type">PDF</span>
            </div>
            <div class="file-row">
              <div class="file-badge xls">XLS</div>
              <span class="file-name">Buy Estimator Premium</span>
              <span class="file-type">Calculator</span>
            </div>
            <div class="file-row">
              <div class="file-badge xls">XLS</div>
              <span class="file-name">Deal Comparison Sheet</span>
              <span class="file-type">Calculator</span>
            </div>
            <div class="file-row">
              <div class="file-badge xls">XLS</div>
              <span class="file-name">Lease Estimator</span>
              <span class="file-type">Calculator</span>
            </div>
            <div class="file-row">
              <div class="file-badge xls">XLS</div>
              <span class="file-name">Lease vs Buy Comparison</span>
              <span class="file-type">Calculator</span>
            </div>
            <div class="file-row">
              <div class="file-badge pdf">PDF</div>
              <span class="file-name">README — Toolkit Instructions</span>
              <span class="file-type">Guide</span>
            </div>
            <div class="file-row">
              <div class="file-badge pdf">PDF</div>
              <span class="file-name">README — Buy Estimator</span>
              <span class="file-type">Guide</span>
            </div>
            <div class="file-row">
              <div class="file-badge pdf">PDF</div>
              <span class="file-name">README — Lease vs Buy</span>
              <span class="file-type">Guide</span>
            </div>
          </div>

          <!-- How to start -->
          <div class="howto-label">Start here — in this order</div>

          <div class="steps-list">
            <div class="step-row">
              <div class="step-num">1</div>
              <div class="step-text">
                <strong>Tonight — Read the Toolkit PDF</strong>
                Start with the First-Time Buyer Checklist. Two minutes. Sets the whole process.
              </div>
            </div>
            <div class="step-row">
              <div class="step-num">2</div>
              <div class="step-text">
                <strong>Before contacting dealers — Run your numbers</strong>
                Open the Buy Estimator or Lease Estimator. Set your real max OTD before anyone knows your budget.
              </div>
            </div>
            <div class="step-row">
              <div class="step-num">3</div>
              <div class="step-text">
                <strong>Copy the OTD email — Send it to 5–8 dealers at once</strong>
                Competition is your most powerful tool. One quote is not a negotiation.
              </div>
            </div>
            <div class="step-row">
              <div class="step-num">4</div>
              <div class="step-text">
                <strong>On pickup day — Bring the Delivery Checklist</strong>
                Print it. Check every item before you sign. A deposit is not a contract.
              </div>
            </div>
          </div>

          <!-- Actions -->
